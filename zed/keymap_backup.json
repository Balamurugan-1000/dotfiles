// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-w ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-w ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-w ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-w ctrl-j": "workspace::ActivatePaneDown",

      "space e": "workspace::ToggleLeftDock",
      "space f": "file_finder::Toggle",
      "space p": "command_palette::Toggle",
    },
  },

  {
    "context": "Terminal",
    "bindings": {
      "ctrl-k": "workspace::ActivateNextPane",
    },
  },

  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-l": "workspace::ActivateNextPane",
    },
  },

  {
    "context": "ProjectPanel && vim_mode == normal",
    "bindings": {
      "a": "project_panel::NewFile",
      "shift a": "project_panel::NewDirectory",
      "d": "project_panel::Delete",
      "r": "project_panel::Rename",
      "y": "workspace::CopyPath",
      "enter": "project_panel::Open",
    },
  },

  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
      "ctrl-h": ["workspace::ActivatePaneInDirection", "Left"],
      "ctrl-l": ["workspace::ActivatePaneInDirection", "Right"],
      "ctrl-k": ["workspace::ActivatePaneInDirection", "Up"],
      "ctrl-j": ["workspace::ActivatePaneInDirection", "Down"],
    },
  },
]
