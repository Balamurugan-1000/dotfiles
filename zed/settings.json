// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "terminal": {
    "dock": "right"
  },
  "project_panel": {
    "entry_spacing": "comfortable",
    "dock": "left"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "edit_predictions": {
    "provider": "copilot",
    "mode": "eager"
  },
"agent": {
  "show_turn_stats": true,
  "single_file_review": true,
  "tool_permissions": {
   "default": "confirm",
   "tools": {}
  },
  "enabled": true,
  "default_model": {
    "provider": "google",
    "model": "gemini-2.5-flash"
  },
  "model_parameters": [],
  "providers": [
    {
      "name": "opencode",
      "type": "acp",
      "command": "opencode",
      "args": ["acp"]
    }
  ]
},
  "preview_tabs": {
    "enabled": false
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "vim_mode": true,
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "Catppuccin Macchiato",
  "agent_servers": {
    "OpenCode": {
      "type": "custom",
      "command": "opencode",
      "args": ["acp"]
    }
  }
}
